---
import { ViewTransitions } from "astro:transitions";
import { THEME_COLOR_NAVY } from "../lib/theme-chrome";
import "../styles/theme.css";
import "../styles/ui.css";

interface Props {
  title: string;
  activeTab: "ingest" | "search" | "login";
}

const { title, activeTab } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="theme-color" content={THEME_COLOR_NAVY} />
    <meta name="description" content="StackMark — your personal bookmark manager" />
    <!-- Sync auth gate before body parses — must match keys in src/lib/auth-client.ts -->
    {
      activeTab !== "login" && (
        <script is:inline>
          (function () {
            try {
              if (
                localStorage.getItem("stackmark_access_token") ||
                localStorage.getItem("stackmark_refresh_token")
              )
                return;
              var path = location.pathname + location.search;
              var q =
                path && !path.startsWith("/login")
                  ? "?redirect=" + encodeURIComponent(path)
                  : "";
              location.replace("/login" + q);
            } catch (e) {}
          })();
        </script>
      )
    }
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="192x192" href="/icon-192.png" />
    <title>{title}</title>
    <ViewTransitions />
    <script is:inline>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js");
      }
    </script>
    <script>
      import { isLoggedIn, logout } from "../lib/auth-client";

      function updateAuthNav() {
        const tabs = document.getElementById("nav-app-tabs");
        const slot = document.getElementById("nav-auth-slot");
        const el = document.getElementById("nav-auth-link") as HTMLAnchorElement | null;
        if (!slot || !el) return;

        const loggedIn = isLoggedIn();
        if (tabs) {
          tabs.style.display = loggedIn ? "flex" : "";
        }

        slot.style.display = "";
        if (loggedIn) {
          el.textContent = "Sign out";
          el.href = "#";
          el.onclick = (e) => {
            e.preventDefault();
            logout();
            window.location.href = "/login";
          };
        } else {
          el.textContent = "Sign in";
          el.href = "/login";
          el.onclick = null;
        }
      }

      document.addEventListener("astro:page-load", updateAuthNav);
    </script>
    <script>
      import { initVantaDots } from "../lib/vanta-dots";

      document.addEventListener("astro:page-load", () => {
        void initVantaDots();
      });
    </script>
  </head>
  <body>
    <div id="vanta-bg" class="vanta-bg" aria-hidden="true"></div>
    <nav>
      <div class="nav-left">
        <a href="/" class="logo">StackMark</a>
      </div>
      <div class="nav-center" id="nav-app-tabs">
        <a href="/" class:list={["tab", { active: activeTab === "ingest" }]}>
          Ingest
        </a>
        <a
          href="/search"
          class:list={["tab", { active: activeTab === "search" }]}
        >
          Search
        </a>
      </div>
      {
        activeTab !== "login" && (
          <div class="nav-right" id="nav-auth-slot">
            <a href="/login" id="nav-auth-link" class="auth-link">
              Sign in
            </a>
          </div>
        )
      }
    </nav>
    <main transition:animate="fade">
      <slot />
    </main>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    overflow-x: hidden;
  }

  html,
  body {
    height: 100%;
    max-width: 100%;
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    background: var(--surface);
    color: var(--text-primary);
  }

  body {
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  /* Vanta.js DOTS canvas — mouse uses window events; keep clicks for UI */
  .vanta-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  main {
    position: relative;
    z-index: 1;
  }

  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 64px;
    background: var(--navy);
    flex-shrink: 0;
  }

  .nav-left,
  .nav-right {
    width: 160px;
  }

  .nav-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .auth-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    transition: color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }

  .auth-link:hover {
    color: var(--text-primary);
    background: var(--tint-orange-medium);
    box-shadow: var(--ring-orange-35);
  }

  .nav-center {
    display: flex;
    gap: 0.5rem;
  }

  /* Shown as flex via inline style when logged in (see updateAuthNav). */
  #nav-app-tabs {
    display: none;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .tab {
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }

  .tab:hover:not(.active) {
    color: var(--text-primary);
    background: var(--tint-orange-soft);
    box-shadow: var(--ring-orange-32);
  }

  .tab.active {
    color: white;
    background: var(--orange);
  }

  .tab.active:hover {
    background: var(--orange-hover);
    box-shadow: var(--ring-orange-45);
  }

  .tab:focus-visible,
  .auth-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-nav);
  }

  .tab.active:focus-visible {
    box-shadow: var(--focus-ring-nav-active);
  }

  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    min-width: 0;
    width: 100%;
  }

  /* Mobile responsive */
  @media (max-width: 640px) {
    main {
      overflow-x: clip;
      box-sizing: border-box;
      padding-left: max(1rem, env(safe-area-inset-left));
      padding-right: max(1rem, env(safe-area-inset-right));
    }

    nav {
      padding: 0 1rem;
      height: 56px;
      padding-left: max(1rem, env(safe-area-inset-left));
      padding-right: max(1rem, env(safe-area-inset-right));
    }

    .nav-left {
      width: auto;
    }

    .nav-right {
      width: auto;
    }

    .logo {
      font-size: 1.1rem;
    }

    .tab {
      padding: 0.4rem 0.9rem;
      font-size: 0.8rem;
    }

  }
</style>
