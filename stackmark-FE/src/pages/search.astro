---
import Layout from "../layouts/Layout.astro";
---

<Layout title="StackMark — Search" activeTab="search">
  <div class="search-container">
    <div id="results-area" class="results-area">
      <div class="empty-state">
        <p>Search your saved bookmarks</p>
        <span>Type a query below to find what you're looking for</span>
      </div>
    </div>
    <div class="search-bar">
      <input
        type="text"
        id="search-input"
        placeholder="Search your bookmarks..."
        autocomplete="off"
      />
      <button id="search-btn" class="btn-primary btn-primary--icon" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
</Layout>

<style>
  .search-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .results-area {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem 2rem;
    /* Space for fixed search bar + safe area (bar ~72px + padding) */
    padding-bottom: calc(5.5rem + env(safe-area-inset-bottom, 0px));
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: #5a7a9e;
  }

  .empty-state p {
    font-size: 1.125rem;
    font-weight: 500;
    color: #a0b4d0;
  }

  .empty-state span {
    font-size: 0.85rem;
  }

  .search-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
    background: #0a1929;
    border-top: 1px solid #1d2b3c;
    flex-shrink: 0;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.35);
  }

  .search-bar input {
    flex: 1;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    border: 1px solid #1d2b3c;
    background: #051424;
    color: #d5e4fa;
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .search-bar input::placeholder {
    color: #5a7a9e;
  }

  .search-bar input:focus {
    border-color: #ff671f;
    box-shadow: 0 0 0 2px rgba(255, 103, 31, 0.35);
  }

  .search-bar button svg {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 640px) {
    .results-area {
      padding: 1rem;
      padding-bottom: calc(5.25rem + env(safe-area-inset-bottom, 0px));
    }

    .search-bar {
      padding: 0.75rem 1rem;
      padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
    }

    .search-bar input {
      font-size: 1rem;
      padding: 0.85rem 1rem;
    }

    .empty-state p {
      font-size: 1rem;
    }

    .empty-state span {
      font-size: 0.8rem;
    }
  }
</style>

<style is:global>
  .result-card {
    background: #122031;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.2s ease;
  }

  .result-card:hover {
    background: #1d2b3c;
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #d5e4fa;
  }

  .card-score {
    font-size: 0.8rem;
    font-weight: 600;
    color: #ff671f;
    white-space: nowrap;
  }

  .card-description {
    font-size: 0.85rem;
    color: #a0b4d0;
    line-height: 1.4;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card-source {
    font-size: 0.75rem;
    font-weight: 500;
    color: #b4c5ff;
    background: #1c3f94;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    text-transform: capitalize;
  }

  .card-tag {
    font-size: 0.7rem;
    color: #a0b4d0;
    background: #1d2b3c;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
  }

  .card-url {
    font-size: 0.75rem;
    color: #5a7a9e;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    display: block;
  }

  .card-url:hover {
    color: #b4c5ff;
  }

  .loading {
    text-align: center;
    color: #5a7a9e;
    padding: 2rem;
  }

  @media (max-width: 640px) {
    .result-card {
      padding: 0.85rem 1rem;
    }

    .card-title {
      font-size: 0.9rem;
    }

    .card-description {
      font-size: 0.8rem;
    }

    .card-url {
      font-size: 0.7rem;
    }
  }
</style>

<script>
  import {
    AuthRedirectError,
    fetchWithAuth,
    isLoggedIn,
    redirectToLogin,
  } from "../lib/auth-client";

  document.addEventListener("astro:page-load", () => {
    const input = document.getElementById("search-input") as HTMLInputElement;
    const btn = document.getElementById("search-btn") as HTMLButtonElement;
    const resultsArea = document.getElementById("results-area") as HTMLDivElement;
    if (!input || !btn || !resultsArea) return;

    if (!isLoggedIn()) {
      redirectToLogin();
      return;
    }

    function escapeHtml(str: string): string {
      return str
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    function renderResults(results: any[]) {
      if (results.length === 0) {
        resultsArea.innerHTML = `
          <div class="empty-state">
            <p>No results found</p>
            <span>Try a different query</span>
          </div>`;
        return;
      }

      resultsArea.innerHTML = results
        .map((r: any) => {
          const heading = String(r.heading ?? "").trim();
          const brief = String(r.brief ?? "").trim();
          const score =
            r.similarity != null
              ? `${Math.round(r.similarity * 100)}%`
              : "";
          const source = r.source || "web";
          const url = r.url || "";

          let title: string;
          let body: string;
          if (heading) {
            title = heading;
            body = brief;
          } else if (brief) {
            title = brief.length > 80 ? `${brief.slice(0, 80)}…` : brief;
            body = brief.length > 80 ? brief : "";
          } else {
            try {
              title = url ? new URL(url).hostname.replace(/^www\./, "") : "Bookmark";
            } catch {
              title = "Bookmark";
            }
            body = "";
          }

          const bodyHtml =
            body.length > 0
              ? `<p class="card-description">${escapeHtml(body.length > 400 ? `${body.slice(0, 400)}…` : body)}</p>`
              : "";

          return `
          <div class="result-card">
            <div class="card-header">
              <span class="card-title">${escapeHtml(title)}</span>
              ${score ? `<span class="card-score">${score} match</span>` : ""}
            </div>
            ${bodyHtml}
            <div class="card-meta">
              <span class="card-source">${escapeHtml(source)}</span>
            </div>
            ${url ? `<a class="card-url" href="${escapeHtml(url)}" target="_blank" rel="noopener">${escapeHtml(url)}</a>` : ""}
          </div>`;
        })
        .join("");
    }

    async function doSearch() {
      const query = input.value.trim();
      if (!query) return;

      btn.disabled = true;
      resultsArea.innerHTML = `<div class="loading">Searching...</div>`;

      try {
        const res = await fetchWithAuth("/search", {
          method: "POST",
          body: JSON.stringify({ query, top_k: 5 }),
        });
        const data = await res.json();

        if (data.success) {
          renderResults(data.data || []);
        } else {
          resultsArea.innerHTML = `
            <div class="empty-state">
              <p>Error</p>
              <span>${escapeHtml(data.error || "Something went wrong")}</span>
            </div>`;
        }
      } catch (e) {
        if (e instanceof AuthRedirectError) return;
        resultsArea.innerHTML = `
          <div class="empty-state">
            <p>Could not reach the server</p>
            <span>Make sure the backend is running</span>
          </div>`;
      } finally {
        btn.disabled = false;
      }
    }

    btn.addEventListener("click", doSearch);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") doSearch();
    });
  });
</script>
