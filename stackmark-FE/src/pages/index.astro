---
import Layout from "../layouts/Layout.astro";
---

<Layout title="StackMark — Ingest" activeTab="ingest">
  <div class="ingest-container">
    <h2 class="heading">Drop a link</h2>
    <div class="input-row">
      <input
        type="url"
        id="url-input"
        placeholder="Paste any URL here..."
        autocomplete="off"
      />
      <button id="save-btn" class="btn-primary btn-primary--pill">Save Bookmark</button>
    </div>
    <p id="status-msg" class="status"></p>
  </div>
</Layout>

<style>
  .ingest-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 2rem;
  }

  .heading {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 600px;
    padding: 0 1.5rem;
  }

  input {
    flex: 1;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    border: 1px solid var(--navy-lighter);
    background: var(--navy);
    color: var(--text-primary);
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  #url-input {
    margin-left: 0px;
    margin-right: 0px;
    box-sizing: border-box;
  }

  input::placeholder {
    color: var(--text-muted);
  }

  input:focus {
    border-color: var(--orange);
    box-shadow: var(--focus-ring);
  }

  #save-btn {
    white-space: nowrap;
  }

  .status {
    font-size: 0.85rem;
    min-height: 1.25rem;
  }

  .status.success {
    color: var(--success);
  }

  .status.error {
    color: var(--error);
  }

  @media (max-width: 640px) {
    .ingest-container {
      padding: 1.5rem 1rem;
    }

    .heading {
      font-size: 1.25rem;
    }

    .input-row {
      flex-direction: column;
      gap: 0.5rem;
    }

    input {
      width: 100%;
      font-size: 1rem;
      padding: 0.85rem 1rem;
    }

    #save-btn {
      width: 100%;
      padding: 0.85rem;
      font-size: 0.9rem;
    }
  }
</style>

<script>
  import {
    AuthRedirectError,
    fetchWithAuth,
    isLoggedIn,
    redirectToLogin,
  } from "../lib/auth-client";

  document.addEventListener("astro:page-load", () => {
    const input = document.getElementById("url-input") as HTMLInputElement;
    const btn = document.getElementById("save-btn") as HTMLButtonElement;
    const status = document.getElementById("status-msg") as HTMLParagraphElement;
    if (!input || !btn || !status) return;

    if (!isLoggedIn()) {
      redirectToLogin();
      return;
    }

    // Handle shared URLs from mobile share sheet
    const params = new URLSearchParams(window.location.search);
    const sharedUrl = params.get("url") || params.get("text") || "";
    if (sharedUrl) {
      // Extract URL from shared text (apps sometimes send "title\nurl" or just the url)
      const urlMatch = sharedUrl.match(/https?:\/\/[^\s]+/);
      if (urlMatch) {
        input.value = urlMatch[0];
      } else {
        input.value = sharedUrl;
      }
      // Clean up the URL bar
      window.history.replaceState({}, "", "/");
    }

    btn.addEventListener("click", async () => {
      const url = input.value.trim();
      if (!url) {
        status.textContent = "Please enter a URL";
        status.className = "status error";
        return;
      }

      btn.disabled = true;
      btn.textContent = "Saving...";
      status.textContent = "";
      status.className = "status";

      try {
        const res = await fetchWithAuth("/ingest", {
          method: "POST",
          body: JSON.stringify({ url }),
        });
        const data = await res.json();

        if (data.success) {
          status.textContent = "Bookmark saved!";
          status.className = "status success";
          input.value = "";
        } else {
          status.textContent = data.error || "Something went wrong";
          status.className = "status error";
        }
      } catch (e) {
        if (e instanceof AuthRedirectError) return;
        status.textContent = "Could not reach the server";
        status.className = "status error";
      } finally {
        btn.disabled = false;
        btn.textContent = "Save Bookmark";
      }
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") btn.click();
    });
  });
</script>
