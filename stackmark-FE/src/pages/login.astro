---
import Layout from "../layouts/Layout.astro";
---

<Layout title="StackMark — Sign in" activeTab="login">
  <div class="login-container">
    <h2 class="heading">Sign in</h2>
    <form id="login-form" class="login-form">
      <label class="field">
        <span>Username</span>
        <input
          type="text"
          id="username"
          name="username"
          autocomplete="username"
          required
        />
      </label>
      <label class="field">
        <span>Password</span>
        <input
          type="password"
          id="password"
          name="password"
          autocomplete="current-password"
          required
        />
      </label>
      <button type="submit" id="submit-btn" class="btn-primary btn-primary--pill">
        Sign in
      </button>
    </form>
    <p id="status-msg" class="status"></p>
  </div>
</Layout>

<style>
  .login-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 2rem;
    max-width: 400px;
    margin: 0 auto;
    width: 100%;
  }

  .heading {
    font-size: 1.5rem;
    font-weight: 600;
    color: #d5e4fa;
    letter-spacing: -0.02em;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: #a0b4d0;
  }

  .field input {
    padding: 0.75rem 1rem;
    border-radius: 10px;
    border: 1px solid #1d2b3c;
    background: #0a1929;
    color: #d5e4fa;
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .field input:focus {
    border-color: #ff671f;
    box-shadow: 0 0 0 2px rgba(255, 103, 31, 0.35);
  }

  #submit-btn {
    margin-top: 0.25rem;
  }

  .status {
    font-size: 0.85rem;
    min-height: 1.25rem;
    text-align: center;
  }

  .status.error {
    color: #f97386;
  }
</style>

<script>
  import { login } from "../lib/auth-client";

  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("login-form") as HTMLFormElement;
    const status = document.getElementById("status-msg") as HTMLParagraphElement;
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    if (!form || !status || !btn) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const username = String(fd.get("username") ?? "").trim();
      const password = String(fd.get("password") ?? "");
      if (!username) return;

      btn.disabled = true;
      status.textContent = "";
      status.className = "status";

      try {
        const result = await login(username, password);
        if (result.ok) {
          const params = new URLSearchParams(window.location.search);
          const redirect = params.get("redirect");
          window.location.href =
            redirect && redirect.startsWith("/") ? redirect : "/";
        } else {
          status.textContent = result.error;
          status.className = "status error";
        }
      } catch {
        status.textContent = "Could not reach the server";
        status.className = "status error";
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
