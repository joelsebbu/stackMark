{
  "name": "StackMark",
  "short_name": "StackMark",
  "description": "Personal bookmark manager with semantic search",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#051424",
  "theme_color": "#0a1929",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/?shared=true",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
